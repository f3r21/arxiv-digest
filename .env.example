# Plantilla de configuracion. Copia a `.env` y rellena.
# El archivo `.env` NO se versiona (esta en .gitignore).

# ==============================================================
#  MODO DEV (default): MailHog local, sin credenciales reales
# ==============================================================
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_USE_TLS=0
FROM_ADDR=arxiv-digest@local
REPLY_TO=
# RECIPIENT: solo se usa como suscriptor "seed" si esta seteado y NO es @local.
# Para multi-suscriptor de verdad: usa el formulario web (subscriptions service).
RECIPIENT=

INBOX_BACKEND=mailhog
MAILHOG_API=http://mailhog:8025/api/v2/messages
MAILHOG_DELETE_API=http://mailhog:8025/api/v1/messages
SELF_ADDR=arxiv-digest@local

MAILSAC_API_KEY=
MAILSAC_INBOX=

# Categorias arXiv (legacy). YA NO SE USAN: cada suscriptor elige las suyas
# desde el formulario web. Se mantiene por compatibilidad.
ARXIV_CATEGORIES=

DIGEST_HOUR=07:00
RUN_NOW=0
TRANSLATOR_URL=http://translator:8000
POLL_INTERVAL_S=30
TZ=America/Lima

# ==============================================================
#  Subscriptions service + reverse proxy
# ==============================================================
# Dominio publico que apunta al stack. En dev usa "localhost".
SUBSCRIPTIONS_DOMAIN=localhost
# Base URL absoluta para construir links de confirm/unsubscribe en los emails.
# Dev: https://localhost (cert autofirmado). Prod: https://digest.tu-dominio.com
PUBLIC_BASE_URL=https://localhost
# Email para Let's Encrypt (solo prod). Vacio = anonymous ACME.
ADMIN_EMAIL=
# Secret para firmar tokens de confirm/unsubscribe.
# Genera con: openssl rand -hex 32
SUBSCRIPTIONS_SECRET=change-me-openssl-rand-hex-32

# Anti-abuso del formulario
SUBSCRIBE_RATE_PER_HOUR=5
CONFIRM_TTL_HOURS=48
DISPOSABLE_DOMAIN_BLOCKLIST=mailinator.com,guerrillamail.com,10minutemail.com

# Seed automatico del suscriptor al startup desde RECIPIENT (opcional).
# Si RECIPIENT esta seteado (y no es @local) se inserta como suscriptor seed
# con estas categorias y keywords. Util para migrar setups single-user previos.
SEED_SUBSCRIBER_CATEGORIES=cs.DC,cs.AI
SEED_SUBSCRIBER_KEYWORDS=

# Debug endpoint /admin/subscribers. NO prender en prod publico.
EXPOSE_ADMIN=0

# ==============================================================
#  MODO LIVE: Resend/Brevo (saliente) + Mailsac (entrante)
#  Descomenta y reemplaza los valores de arriba con los de abajo.
# ==============================================================
# --- SMTP saliente via Brevo (300/dia gratis) ---
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=tu-login@smtp-brevo.com          # del panel Brevo > SMTP & API
# SMTP_PASS=xxxxxxxxxxxxxxxx                 # SMTP key (no la API key REST)
# SMTP_USE_TLS=1
# FROM_ADDR=digest@tu-dominio.com            # dominio verificado con DKIM/SPF
# REPLY_TO=tu-inbox@mailsac.com              # inbox de Mailsac

# --- Inbox entrante via Mailsac (1500 calls/mes gratis) ---
# INBOX_BACKEND=mailsac
# MAILSAC_API_KEY=k_xxxxxxxxxxxxxxxx
# MAILSAC_INBOX=tu-inbox@mailsac.com         # mismo que REPLY_TO
# POLL_INTERVAL_S=600                         # 10 min => ~4320 calls/mes
