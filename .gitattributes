# Normaliza fin de linea: LF en el repo. Evita que un checkout en Windows
# (core.autocrlf=true) convierta a CRLF y rompa codigo que corre en contenedores Linux.
* text=auto eol=lf

# Archivos de texto que deben ser LF si o si
*.py          text eol=lf
*.sh          text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.txt         text eol=lf
*.md          text eol=lf
*.json        text eol=lf
Dockerfile    text eol=lf
.gitignore    text eol=lf
.gitattributes text eol=lf
.dockerignore text eol=lf

# Binarios: git no debe tocarlos
*.db   binary
*.pdf  binary
