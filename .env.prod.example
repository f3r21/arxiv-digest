# Plantilla de configuracion para PRODUCCION (VPS real).
# Copiar a .env.prod en el servidor y rellenar.
# .env.prod esta en .gitignore -- no se commitea.

# ==============================================================
#  Docker Hub (imagenes pre-built)
# ==============================================================
# Tu username en hub.docker.com. El compose.prod.yml usa
# ${DOCKERHUB_USER}/arxiv-digest-<service>:latest.
# Subir las imagenes con: ./tools/build_and_push.sh
DOCKERHUB_USER=tu-username

# ==============================================================
#  Dominio + reverse proxy
# ==============================================================
# Subdominio publico que apunta al servidor (A record en FreeDNS,
# Cloudflare, etc.). Caddy emite cert de Let's Encrypt en el primer hit.
SUBSCRIPTIONS_DOMAIN=arxivdigest.mooo.com
PUBLIC_BASE_URL=https://arxivdigest.mooo.com
# Email para Let's Encrypt (recibe expiracion warnings)
ADMIN_EMAIL=tu@correo.com

# Secret para firmar tokens. CRITICO: regenerar para prod, NO reusar el de dev.
#   openssl rand -hex 32
SUBSCRIPTIONS_SECRET=__regenerar_con_openssl_rand_hex_32__

# ==============================================================
#  SMTP saliente (Resend con dominio verificado)
# ==============================================================
# Crear cuenta en resend.com, verificar el dominio con DKIM/SPF/DMARC.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxx
SMTP_USE_TLS=1
# Despues que verifiques el dominio en Resend, usar tu propio FROM:
FROM_ADDR=digest@arxivdigest.mooo.com
# Reply-To apunta al inbox de Mailsac que el listener polea
REPLY_TO=arxiv-replies@mailsac.com
# RECIPIENT solo se usa para AUTO-SEED del primer suscriptor en cold start.
# Si esta vacio o termina en @local, no se crea seed.
RECIPIENT=tu@correo.com

# ==============================================================
#  Inbox entrante (Mailsac)
# ==============================================================
INBOX_BACKEND=mailsac
MAILSAC_API_KEY=k_xxxxxxxxxxxxxxxxxx
MAILSAC_INBOX=arxiv-replies@mailsac.com
SELF_ADDR=digest@arxivdigest.mooo.com
# 10 min => ~4320 calls/mes (cap gratis Mailsac = 1500/mes; ojo)
POLL_INTERVAL_S=600

# ==============================================================
#  Monitoring (Healthchecks.io free)
# ==============================================================
# 1) Crear cuenta en https://healthchecks.io (GitHub login OK)
# 2) Add Check con schedule cron "0 7 * * *" y grace 25h
# 3) Copiar el ping URL aca
# Si vacio: silent fail, sin monitoring. Si seteado: digest POST a ping
# URL despues de cada run; healthchecks.io alerta por email/slack/telegram
# si no llega ping en 25h.
HEALTHCHECK_URL=

# ==============================================================
#  Subscriptions / anti-abuso
# ==============================================================
SUBSCRIBE_RATE_PER_HOUR=10
CONFIRM_TTL_HOURS=48
DISPOSABLE_DOMAIN_BLOCKLIST=mailinator.com,guerrillamail.com,10minutemail.com,tempmail.com
SEED_SUBSCRIBER_CATEGORIES=cs.DC,cs.AI
SEED_SUBSCRIBER_KEYWORDS=
# NUNCA poner 1 en prod publico (expone /admin/subscribers sin auth)
EXPOSE_ADMIN=0

# ==============================================================
#  Digest / translator
# ==============================================================
DIGEST_HOUR=07:00
RUN_NOW=0
TRANSLATOR_URL=http://translator:8000
MYMEMORY_EMAIL=
TZ=America/Lima
ARXIV_CATEGORIES=
